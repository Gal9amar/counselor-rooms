generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Room {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  createdAt     DateTime       @default(now())
  shifts        Shift[]
  scheduleSlots ScheduleSlot[]
}

model Therapist {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  createdAt     DateTime       @default(now())
  shifts        Shift[]
  scheduleSlots ScheduleSlot[]
}

model Shift {
  id          Int       @id @default(autoincrement())
  therapistId Int
  roomId      Int
  startTime   DateTime  @default(now())
  endTime     DateTime?
  therapist   Therapist @relation(fields: [therapistId], references: [id])
  room        Room      @relation(fields: [roomId], references: [id])

  @@index([therapistId])
  @@index([roomId])
}

model ScheduleSlot {
  id          Int       @id @default(autoincrement())
  roomId      Int
  dayOfWeek   Int       // 0=Sun 1=Mon 2=Tue 3=Wed 4=Thu 5=Fri
  hour        Int       // 8..17
  therapistId Int
  createdAt   DateTime  @default(now())
  room        Room      @relation(fields: [roomId], references: [id])
  therapist   Therapist @relation(fields: [therapistId], references: [id])

  @@unique([roomId, dayOfWeek, hour])
  @@index([therapistId])
}
